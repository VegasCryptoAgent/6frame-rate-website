rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Videos collection - Publicly readable
    match /videos/{videoId} {
      allow read: if true;
      allow write: if false;
    }

    // System collection for connection test
    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
